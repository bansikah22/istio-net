<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Prime Number Calculator</title>
  <style>
    body { font-family: sans-serif; text-align: center; margin-top: 50px; }
    .container { max-width: 500px; margin: auto; padding: 20px; border: 1px solid #ccc; border-radius: 10px; }
    .version { position: fixed; top: 10px; right: 10px; padding: 5px 10px; border-radius: 5px; }
    .v1 { background-color: #3498db; color: white; }
    .v2 { background-color: #2ecc71; color: white; }
    .result { margin-top: 20px; text-align: left; }
  </style>
</head>
<body>
  <div class="container">
    <div class="version <%= version === '1.0.0' ? 'v1' : 'v2' %>">
      Version: <%= version %>
    </div>
    <h1>Prime Number Calculator</h1>
    <form action="/calculate" method="POST">
      <label for="number">Find all prime numbers up to:</label>
      <input type="number" id="number" name="number" required>
      <button type="submit">Calculate</button>
    </form>

    <% if (error) { %>
      <p style="color: red;"><%= error %></p>
    <% } %>

    <% if (number !== null) { %>
      <div class="result">
        <h2>Results for <%= number %></h2>
        <p>Found <%= primes.length %> prime numbers in <%= time %> seconds.</p>
        <p><%= primes.join(', ') %></p>
      </div>
    <% } %>
  </div>
</body>
</html>
